<?xml version="1.0"?>
<listing xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <argument name="data" xsi:type="array">
        <item name="js_config" xsi:type="array">
            <item name="provider" xsi:type="string">magebatch_inventory_history_listing.magebatch_inventory_history_listing_data_source</item>
        </item>
    </argument>
    <settings>
        <spinner>magebatch_inventory_history_columns</spinner>
        <deps>
            <dep>magebatch_inventory_history_listing.magebatch_inventory_history_listing_data_source</dep>
        </deps>
    </settings>
    <dataSource name="magebatch_inventory_history_listing_data_source" component="Magento_Ui/js/grid/provider">
        <settings>
            <storageConfig>
                <param name="indexField" xsi:type="string">history_id</param>
            </storageConfig>
            <updateUrl path="mui/index/render"/>
        </settings>
        <aclResource>MageBatch_Inventory::inventory_view</aclResource>
        <dataProvider class="MageBatch\Inventory\Ui\DataProvider\History\ListingDataProvider" name="magebatch_inventory_history_listing_data_source">
            <settings>
                <requestFieldName>id</requestFieldName>
                <primaryFieldName>history_id</primaryFieldName>
            </settings>
        </dataProvider>
    </dataSource>
    <listingToolbar name="listing_top">
        <settings>
            <sticky>true</sticky>
        </settings>
        <bookmark name="bookmarks"/>
        <columnsControls name="columns_controls"/>
        <filters name="listing_filters"/>
        <paging name="listing_paging"/>
    </listingToolbar>
    <columns name="magebatch_inventory_history_columns">
        <column name="history_id">
            <settings>
                <filter>text</filter>
                <label translate="true">ID</label>
                <sorting>asc</sorting>
            </settings>
        </column>
        <column name="batch_id">
            <settings>
                <filter>text</filter>
                <label translate="true">Batch ID</label>
            </settings>
        </column>
        <column name="product_sku">
            <settings>
                <filter>text</filter>
                <label translate="true">Product SKU</label>
            </settings>
        </column>
        <column name="action">
            <settings>
                <filter>text</filter>
                <label translate="true">Action</label>
            </settings>
        </column>
        <column name="qty_before">
            <settings>
                <filter>text</filter>
                <label translate="true">Qty Before</label>
            </settings>
        </column>
        <column name="qty_after">
            <settings>
                <filter>text</filter>
                <label translate="true">Qty After</label>
            </settings>
        </column>
        <column name="created_at">
            <settings>
                <filter>date</filter>
                <label translate="true">Created At</label>
            </settings>
        </column>
    </columns>
</listing>
