<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Cron:etc/crontab.xsd">
    <group id="default">
        <job name="magebatch_inventory_process_expired" instance="MageBatch\Inventory\Cron\ProcessExpiredBatches" method="execute">
            <schedule>0 0 * * *</schedule>
        </job>
        <job name="magebatch_inventory_send_expiry_alerts" instance="MageBatch\Inventory\Cron\SendExpiryNotifications" method="execute">
            <schedule>0 6 * * *</schedule>
        </job>
    </group>
</config>
