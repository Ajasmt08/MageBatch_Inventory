<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
    <table name="magebatch_inventory_batch" resource="default" engine="innodb" comment="Inventory Batch">
        <column xsi:type="int" name="batch_id" padding="10" unsigned="true" nullable="false" identity="true" comment="Batch ID"/>
        <column xsi:type="varchar" name="batch_number" length="64" nullable="false" comment="Batch Number"/>
        <column xsi:type="varchar" name="product_sku" length="64" nullable="false" comment="Product SKU"/>
        <column xsi:type="varchar" name="source_code" length="20" nullable="false" comment="Inventory Source Code"/>
        <column xsi:type="decimal" name="qty_received" scale="4" precision="12" nullable="false" default="0"/>
        <column xsi:type="decimal" name="qty_remaining" scale="4" precision="12" nullable="false" default="0"/>
        <column xsi:type="date" name="expiry_date" nullable="false" comment="Expiry Date"/>
        <column xsi:type="date" name="manufacturing_date" nullable="true" comment="Manufacturing Date"/>
        <column xsi:type="varchar" name="supplier" length="128" nullable="true"/>
        <column xsi:type="varchar" name="purchase_order" length="64" nullable="true"/>
        <column xsi:type="decimal" name="cost_price" scale="2" precision="12" nullable="true"/>
        <column xsi:type="smallint" name="status" padding="6" nullable="false" default="1" comment="1=Active 3=Expired 4=Recalled 7=Sold Out"/>
        <column xsi:type="text" name="notes" nullable="true"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="batch_id"/>
        </constraint>
        <constraint xsi:type="unique" referenceId="MAGEBATCH_BATCH_NUM_SRC">
            <column name="batch_number"/>
            <column name="source_code"/>
        </constraint>
        <index referenceId="MAGEBATCH_BATCH_SKU">
            <column name="product_sku"/>
        </index>
        <index referenceId="MAGEBATCH_BATCH_SOURCE">
            <column name="source_code"/>
        </index>
        <index referenceId="MAGEBATCH_BATCH_STATUS">
            <column name="status"/>
        </index>
        <index referenceId="MAGEBATCH_BATCH_EXPIRY">
            <column name="expiry_date"/>
        </index>
    </table>

    <table name="magebatch_inventory_history" resource="default" engine="innodb" comment="Inventory Batch History">
        <column xsi:type="int" name="history_id" padding="10" unsigned="true" nullable="false" identity="true"/>
        <column xsi:type="int" name="batch_id" padding="10" unsigned="true" nullable="false"/>
        <column xsi:type="varchar" name="product_sku" length="64" nullable="false"/>
        <column xsi:type="varchar" name="action" length="32" nullable="false"/>
        <column xsi:type="decimal" name="qty_before" scale="4" precision="12" nullable="true"/>
        <column xsi:type="decimal" name="qty_after" scale="4" precision="12" nullable="true"/>
        <column xsi:type="int" name="admin_id" padding="10" unsigned="true" nullable="true"/>
        <column xsi:type="text" name="reason" nullable="true"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="history_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="MAGEBATCH_HIST_BATCH" table="magebatch_inventory_history" column="batch_id" referenceTable="magebatch_inventory_batch" referenceColumn="batch_id" onDelete="CASCADE"/>
        <index referenceId="MAGEBATCH_HIST_BATCH_IDX">
            <column name="batch_id"/>
        </index>
        <index referenceId="MAGEBATCH_HIST_SKU">
            <column name="product_sku"/>
        </index>
    </table>

    <table name="magebatch_inventory_reservation" resource="default" engine="innodb" comment="Inventory Batch FEFO Reservation">
        <column xsi:type="int" name="reservation_id" padding="10" unsigned="true" nullable="false" identity="true"/>
        <column xsi:type="int" name="batch_id" padding="10" unsigned="true" nullable="false"/>
        <column xsi:type="int" name="order_id" padding="10" unsigned="true" nullable="false"/>
        <column xsi:type="int" name="order_item_id" padding="10" unsigned="true" nullable="false"/>
        <column xsi:type="decimal" name="qty" scale="4" precision="12" nullable="false"/>
        <column xsi:type="timestamp" name="created_at" on_update="false" nullable="false" default="CURRENT_TIMESTAMP"/>
        <constraint xsi:type="primary" referenceId="PRIMARY">
            <column name="reservation_id"/>
        </constraint>
        <constraint xsi:type="foreign" referenceId="MAGEBATCH_RES_BATCH" table="magebatch_inventory_reservation" column="batch_id" referenceTable="magebatch_inventory_batch" referenceColumn="batch_id" onDelete="CASCADE"/>
        <index referenceId="MAGEBATCH_RES_BATCH_IDX">
            <column name="batch_id"/>
        </index>
        <index referenceId="MAGEBATCH_RES_ORDER">
            <column name="order_id"/>
        </index>
    </table>
</schema>
